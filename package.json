{
  "name": "atlas",
  "version": "0.0.0",
  "private": true,
  "description": "Atlas Intelligence Platform — monorepo root.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @atlas/web",
    "dev:api": "npm run dev -w @atlas/api",
    "build:web": "npm run build -w @atlas/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
