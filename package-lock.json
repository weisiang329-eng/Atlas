{
  "name": "atlas",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "atlas",
      "version": "0.0.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=24.0.0",
        "npm": ">=10.0.0"
      }
    },
    "apps/api": {
      "name": "@atlas/api",
      "version": "0.0.0"
    },
    "node_modules/@atlas/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@atlas/database": {
      "resolved": "packages/database",
      "link": true
    },
    "packages/database": {
      "name": "@atlas/database",
      "version": "0.0.0"
    }
  }
}
