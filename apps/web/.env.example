# Atlas Web — environment convention (Sprint 000)
# Copy to `.env.local` for local development. Never commit real secrets.

# Public base URL of the Atlas API (backend scaffold, Issue #1 / Codex).
# The web app talks to the API only through this variable — no hardcoded hosts.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Human-readable environment label shown in the UI status bar.
NEXT_PUBLIC_APP_ENV=local
