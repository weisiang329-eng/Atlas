{
  "name": "@atlas/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Atlas backend — Hono API on Cloudflare Workers, D1 (SQLite) via Drizzle. The intelligence layer behind apps/web.",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply atlas-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply atlas-db --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.3",
    "wrangler": "^3.99.0"
  }
}
